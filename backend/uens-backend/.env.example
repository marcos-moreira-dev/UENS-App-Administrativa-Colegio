# ============================================================
# UENS Backend - Local environment template (.env.example)
# ============================================================
# Como usar este archivo:
# 1. Copia este archivo como ".env" en esta misma carpeta.
# 2. Ajusta valores segun tu maquina o entorno local.
# 3. No subas ".env" real al repositorio (contiene secretos).
#
# Orden de lectura importante:
# - docker-compose usa estas variables para levantar contenedores
# - Spring Boot (por spring.config.import) tambien puede leerlas

# ------------------------------------------------------------
# API / runtime
# ------------------------------------------------------------
# Puerto publicado en host cuando levantas profile "full" en Docker.
# Formato: host:container, donde container suele ser 8080.
APP_PORT=8080

# Perfil de Spring Boot para scripts locales.
# En este proyecto:
# - default: arranque minimo sin DB
# - dev: usa PostgreSQL
# - prod: settings estrictos de produccion
SPRING_PROFILES_ACTIVE=dev

# ------------------------------------------------------------
# Database connection
# ------------------------------------------------------------
# En local con Docker Compose:
# - Postgres escucha 5432 dentro del contenedor
# - se publica como 5433 en host
DB_HOST=localhost
DB_PORT=5433
DB_NAME=SchoolManagerNinitosSonadores
DB_USER=postgres
DB_PASSWORD=postgres

# Opcion alternativa: URL JDBC unica.
# Si defines DB_URL, normalmente prima sobre DB_HOST/DB_PORT/DB_NAME.
# DB_URL=jdbc:postgresql://localhost:5433/SchoolManagerNinitosSonadores

# ------------------------------------------------------------
# JWT (solo valores de desarrollo)
# ------------------------------------------------------------
# Usa una clave de al menos 32 caracteres.
# En produccion esto debe ir desde un secreto gestionado, no hardcodeado.
JWT_SECRET=change-me-local-dev-secret-at-least-32-chars
JWT_ISSUER=uens-local
JWT_EXPIRATION_SECONDS=3600
