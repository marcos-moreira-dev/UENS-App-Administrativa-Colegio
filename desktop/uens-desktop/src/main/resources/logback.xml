<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  Logback configuration for UENS Desktop
  ============================================================
  Objetivo:
  - ver logs en consola para debugging rapido
  - persistir logs en archivo para soporte post-mortem
-->
<configuration>
  <!--
    STDOUT: logs visibles en terminal/IDE.
    Util para desarrollo y diagnostico inmediato.
  -->
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <!--
        Formato recomendado:
        - timestamp: cuando ocurrio
        - level: severidad
        - thread: hilo de ejecucion
        - logger: clase origen
        - msg: mensaje final
      -->
      <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger - %msg%n</pattern>
    </encoder>
  </appender>

  <!--
    FILE: logs persistidos en disco.
    TimeBasedRollingPolicy crea un archivo por dia y conserva historial.
  -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/uens-desktop.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>logs/uens-desktop.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>14</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger - %msg%n</pattern>
    </encoder>
  </appender>

  <!--
    Root logger:
    - nivel INFO por defecto
    - duplica salida a consola y archivo
  -->
  <root level="INFO">
    <appender-ref ref="STDOUT" />
    <appender-ref ref="FILE" />
  </root>
</configuration>
