<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.marcosmoreiradev.uensdesktop.modules.asignaturas.view.AsignaturasController">
  <children>
    <VBox spacing="12" styleClass="screen-card estudiantes-screen">
      <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
      </padding>
      <children>
        <HBox alignment="CENTER_LEFT" spacing="12">
          <children>
            <VBox spacing="4">
              <children>
                <Label text="Asignaturas" styleClass="screen-title" />
                <Label text="Cat&#225;logo acad&#233;mico por &#225;rea y grado." styleClass="muted-label screen-subtitle" />
              </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="crearAsignaturaButton" text="Crear asignatura" onAction="#onCrearAsignatura" styleClass="primary-button" />
          </children>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-row">
          <children>
            <TextField fx:id="queryField" promptText="Buscar por nombre" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="estadoFilter" prefWidth="130" />
            <ComboBox fx:id="gradoFilter" prefWidth="150" promptText="Todos los grados" />
            <TextField fx:id="areaFilterField" promptText="&#193;rea" prefWidth="170" />
            <Button fx:id="buscarButton" text="Buscar" onAction="#onBuscar" styleClass="primary-button" />
            <Button fx:id="limpiarButton" text="Limpiar" onAction="#onLimpiar" />
          </children>
        </HBox>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="table-meta-row">
          <children>
            <Label fx:id="statusLabel" text="Consultando asignaturas..." />
            <Label fx:id="totalLabel" text="0 registros" styleClass="muted-label" />
            <Label fx:id="pageLabel" text="P&#225;gina 1 de 1" styleClass="muted-label" />
          </children>
        </HBox>
        <TableView fx:id="asignaturasTable" prefHeight="520" styleClass="table-view">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="70" text="ID" />
            <TableColumn fx:id="nombreColumn" prefWidth="250" text="Nombre" />
            <TableColumn fx:id="areaColumn" prefWidth="180" text="&#193;rea" />
            <TableColumn fx:id="gradoColumn" prefWidth="100" text="Grado" />
            <TableColumn fx:id="estadoColumn" prefWidth="110" text="Estado" />
            <TableColumn fx:id="accionesColumn" prefWidth="210" text="Acciones" />
          </columns>
        </TableView>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="pager-row">
          <children>
            <Button fx:id="anteriorButton" text="Anterior" onAction="#onPaginaAnterior" />
            <Button fx:id="siguienteButton" text="Siguiente" onAction="#onPaginaSiguiente" styleClass="primary-button" />
          </children>
        </HBox>
      </children>
    </VBox>

    <VBox fx:id="drawerPane" visible="false" managed="false" maxWidth="430" alignment="TOP_LEFT" styleClass="drawer-panel" StackPane.alignment="CENTER_RIGHT">
      <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
      </padding>
      <children>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="drawer-header">
          <children>
            <Label fx:id="drawerTitleLabel" text="Detalle de la asignatura" styleClass="drawer-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Cerrar" onAction="#onCerrarDrawer" />
          </children>
        </HBox>
        <Label fx:id="drawerBannerLabel" text="" wrapText="true" styleClass="banner-label" />
        <StackPane VBox.vgrow="ALWAYS">
          <children>
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="drawer-scroll">
              <content>
                <VBox spacing="16">
                  <children>
                    <VBox fx:id="detailContent" spacing="12" visible="false" managed="false">
                      <children>
                        <Label text="Resumen" styleClass="section-heading" />
                        <HBox spacing="10"><children><Label text="Nombre:" styleClass="detail-key" /><Label fx:id="detailNombreLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="&#193;rea:" styleClass="detail-key" /><Label fx:id="detailAreaLabel" text="-" /></children></HBox>
                        <VBox spacing="6"><children><Label text="Descripci&#243;n" styleClass="detail-key" /><Label fx:id="detailDescripcionLabel" text="-" wrapText="true" /></children></VBox>
                        <HBox spacing="10"><children><Label text="Grado:" styleClass="detail-key" /><Label fx:id="detailGradoLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="Estado:" styleClass="detail-key" /><Label fx:id="detailEstadoLabel" text="-" styleClass="badge-like" /></children></HBox>
                      </children>
                    </VBox>
                    <VBox fx:id="formContent" spacing="12" visible="false" managed="false">
                      <children>
                        <Label text="Datos de la asignatura" styleClass="section-heading" />
                        <VBox spacing="6"><children><Label text="Nombre" styleClass="field-label" /><TextField fx:id="formNombreField" promptText="Nombre" /></children></VBox>
                        <VBox spacing="6"><children><Label text="&#193;rea" styleClass="field-label" /><TextField fx:id="formAreaField" promptText="&#193;rea" /></children></VBox>
                        <VBox spacing="6"><children><Label text="Grado" styleClass="field-label" /><ComboBox fx:id="formGradoCombo" promptText="Selecciona un grado" /></children></VBox>
                        <VBox spacing="6"><children><Label text="Descripci&#243;n" styleClass="field-label" /><TextArea fx:id="formDescripcionArea" promptText="Descripci&#243;n" prefRowCount="5" wrapText="true" /></children></VBox>
                      </children>
                    </VBox>
                  </children>
                </VBox>
              </content>
            </ScrollPane>
            <ImageView fitWidth="236"
                       preserveRatio="true"
                       mouseTransparent="true"
                       styleClass="view-artwork-view drawer-watermark"
                       StackPane.alignment="BOTTOM_RIGHT" />
          </children>
        </StackPane>
        <HBox alignment="CENTER_RIGHT" spacing="10">
          <children>
            <Button fx:id="detailEditarButton" text="Editar" onAction="#onEditarDesdeDetalle" visible="false" managed="false" />
            <Button fx:id="detailEstadoButton" text="Inactivar" onAction="#onCambiarEstadoActual" visible="false" managed="false" />
            <Button fx:id="guardarButton" text="Guardar" onAction="#onGuardarFormulario" styleClass="primary-button" visible="false" managed="false" />
          </children>
        </HBox>
      </children>
    </VBox>
  </children>
</StackPane>
