<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.marcosmoreiradev.uensdesktop.modules.representantes.view.RepresentantesController">
  <children>
    <VBox spacing="12" styleClass="screen-card estudiantes-screen">
      <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
      </padding>
      <children>
        <HBox alignment="CENTER_LEFT" spacing="12">
          <children>
            <VBox spacing="4">
              <children>
                <Label text="Representantes" styleClass="screen-title" />
                <Label text="Listado y mantenimiento de representantes legales." styleClass="muted-label screen-subtitle" />
              </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="crearRepresentanteButton"
                    text="Crear representante"
                    onAction="#onCrearRepresentante"
                    styleClass="primary-button" />
          </children>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-row">
          <children>
            <TextField fx:id="queryField" promptText="Buscar por nombres o apellidos" HBox.hgrow="ALWAYS" />
            <Button fx:id="buscarButton" text="Buscar" onAction="#onBuscar" styleClass="primary-button" />
            <Button fx:id="limpiarButton" text="Limpiar" onAction="#onLimpiar" />
          </children>
        </HBox>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="table-meta-row">
          <children>
            <Label fx:id="statusLabel" text="Consultando representantes..." />
            <Label fx:id="totalLabel" text="0 registros" styleClass="muted-label" />
            <Label fx:id="pageLabel" text="P&#225;gina 1 de 1" styleClass="muted-label" />
          </children>
        </HBox>
        <TableView fx:id="representantesTable" prefHeight="520" styleClass="table-view">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="70" text="ID" />
            <TableColumn fx:id="nombresColumn" prefWidth="170" text="Nombres" />
            <TableColumn fx:id="apellidosColumn" prefWidth="180" text="Apellidos" />
            <TableColumn fx:id="telefonoColumn" prefWidth="150" text="Tel&#233;fono" />
            <TableColumn fx:id="correoColumn" prefWidth="230" text="Correo" />
            <TableColumn fx:id="accionesColumn" prefWidth="150" text="Acciones" />
          </columns>
        </TableView>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="pager-row">
          <children>
            <Button fx:id="anteriorButton" text="Anterior" onAction="#onPaginaAnterior" />
            <Button fx:id="siguienteButton" text="Siguiente" onAction="#onPaginaSiguiente" styleClass="primary-button" />
          </children>
        </HBox>
      </children>
    </VBox>

    <VBox fx:id="drawerPane"
          visible="false"
          managed="false"
          maxWidth="420"
          alignment="TOP_LEFT"
          styleClass="drawer-panel"
          StackPane.alignment="CENTER_RIGHT">
      <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
      </padding>
      <children>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="drawer-header">
          <children>
            <Label fx:id="drawerTitleLabel" text="Detalle del representante" styleClass="drawer-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Cerrar" onAction="#onCerrarDrawer" />
          </children>
        </HBox>
        <Label fx:id="drawerBannerLabel" text="" wrapText="true" styleClass="banner-label" />
        <StackPane VBox.vgrow="ALWAYS">
          <children>
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="drawer-scroll">
              <content>
                <VBox spacing="16">
                  <children>
                    <VBox fx:id="detailContent" spacing="12" visible="false" managed="false">
                      <children>
                        <Label text="Resumen" styleClass="section-heading" />
                        <HBox spacing="10">
                          <children>
                            <Label text="Nombres:" styleClass="detail-key" />
                            <Label fx:id="detailNombresLabel" text="-" />
                          </children>
                        </HBox>
                        <HBox spacing="10">
                          <children>
                            <Label text="Apellidos:" styleClass="detail-key" />
                            <Label fx:id="detailApellidosLabel" text="-" />
                          </children>
                        </HBox>
                        <HBox spacing="10">
                          <children>
                            <Label text="Tel&#233;fono:" styleClass="detail-key" />
                            <Label fx:id="detailTelefonoLabel" text="-" />
                          </children>
                        </HBox>
                        <HBox spacing="10">
                          <children>
                            <Label text="Correo:" styleClass="detail-key" />
                            <Label fx:id="detailCorreoLabel" text="-" wrapText="true" />
                          </children>
                        </HBox>
                      </children>
                    </VBox>

                    <VBox fx:id="formContent" spacing="12" visible="false" managed="false">
                      <children>
                        <Label text="Datos del representante" styleClass="section-heading" />
                        <VBox spacing="6">
                          <children>
                            <Label text="Nombres" styleClass="field-label" />
                            <TextField fx:id="formNombresField" promptText="Nombres" />
                          </children>
                        </VBox>
                        <VBox spacing="6">
                          <children>
                            <Label text="Apellidos" styleClass="field-label" />
                            <TextField fx:id="formApellidosField" promptText="Apellidos" />
                          </children>
                        </VBox>
                        <VBox spacing="6">
                          <children>
                            <Label text="Tel&#233;fono" styleClass="field-label" />
                            <TextField fx:id="formTelefonoField" promptText="Tel&#233;fono" />
                          </children>
                        </VBox>
                        <VBox spacing="6">
                          <children>
                            <Label text="Correo electr&#243;nico" styleClass="field-label" />
                            <TextField fx:id="formCorreoField" promptText="correo@dominio.com" />
                          </children>
                        </VBox>
                      </children>
                    </VBox>
                  </children>
                </VBox>
              </content>
            </ScrollPane>
            <ImageView fitWidth="236"
                       preserveRatio="true"
                       mouseTransparent="true"
                       styleClass="view-artwork-view drawer-watermark"
                       StackPane.alignment="BOTTOM_RIGHT" />
          </children>
        </StackPane>
        <HBox alignment="CENTER_RIGHT" spacing="10">
          <children>
            <Button fx:id="detailEditarButton" text="Editar" onAction="#onEditarDesdeDetalle" visible="false" managed="false" />
            <Button fx:id="guardarButton" text="Guardar" onAction="#onGuardarFormulario" styleClass="primary-button" visible="false" managed="false" />
          </children>
        </HBox>
      </children>
    </VBox>
  </children>
</StackPane>
