<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.marcosmoreiradev.uensdesktop.modules.secciones.view.SeccionesController">
  <children>
    <VBox spacing="12" styleClass="screen-card estudiantes-screen">
      <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
      </padding>
      <children>
        <HBox alignment="CENTER_LEFT" spacing="12">
          <children>
            <VBox spacing="4">
              <children>
                <Label text="Secciones" styleClass="screen-title" />
                <Label text="Configuraci&#243;n acad&#233;mica por grado, paralelo y a&#241;o lectivo." styleClass="muted-label screen-subtitle" />
              </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="crearSeccionButton" text="Crear secci&#243;n" onAction="#onCrearSeccion" styleClass="primary-button" />
          </children>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-row">
          <children>
            <TextField fx:id="queryField" promptText="Buscar por paralelo o a&#241;o lectivo" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="estadoFilter" prefWidth="130" />
            <ComboBox fx:id="gradoFilter" prefWidth="150" promptText="Todos los grados" />
            <TextField fx:id="paraleloFilterField" promptText="Paralelo" prefWidth="130" />
            <TextField fx:id="anioLectivoFilterField" promptText="A&#241;o lectivo" prefWidth="150" />
            <Button fx:id="buscarButton" text="Buscar" onAction="#onBuscar" styleClass="primary-button" />
            <Button fx:id="limpiarButton" text="Limpiar" onAction="#onLimpiar" />
          </children>
        </HBox>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="table-meta-row">
          <children>
            <Label fx:id="statusLabel" text="Consultando secciones..." />
            <Label fx:id="totalLabel" text="0 registros" styleClass="muted-label" />
            <Label fx:id="pageLabel" text="P&#225;gina 1 de 1" styleClass="muted-label" />
          </children>
        </HBox>
        <TableView fx:id="seccionesTable" prefHeight="520" styleClass="table-view">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="70" text="ID" />
            <TableColumn fx:id="gradoColumn" prefWidth="100" text="Grado" />
            <TableColumn fx:id="paraleloColumn" prefWidth="120" text="Paralelo" />
            <TableColumn fx:id="cupoColumn" prefWidth="130" text="Cupo m&#225;ximo" />
            <TableColumn fx:id="anioLectivoColumn" prefWidth="170" text="A&#241;o lectivo" />
            <TableColumn fx:id="estadoColumn" prefWidth="110" text="Estado" />
            <TableColumn fx:id="accionesColumn" prefWidth="210" text="Acciones" />
          </columns>
        </TableView>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="pager-row">
          <children>
            <Button fx:id="anteriorButton" text="Anterior" onAction="#onPaginaAnterior" />
            <Button fx:id="siguienteButton" text="Siguiente" onAction="#onPaginaSiguiente" styleClass="primary-button" />
          </children>
        </HBox>
      </children>
    </VBox>

    <VBox fx:id="drawerPane" visible="false" managed="false" maxWidth="420" alignment="TOP_LEFT" styleClass="drawer-panel" StackPane.alignment="CENTER_RIGHT">
      <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
      </padding>
      <children>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="drawer-header">
          <children>
            <Label fx:id="drawerTitleLabel" text="Detalle de la secci&#243;n" styleClass="drawer-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Cerrar" onAction="#onCerrarDrawer" />
          </children>
        </HBox>
        <Label fx:id="drawerBannerLabel" text="" wrapText="true" styleClass="banner-label" />
        <StackPane VBox.vgrow="ALWAYS">
          <children>
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="drawer-scroll">
              <content>
                <VBox spacing="16">
                  <children>
                    <VBox fx:id="detailContent" spacing="12" visible="false" managed="false">
                      <children>
                        <Label text="Resumen" styleClass="section-heading" />
                        <HBox spacing="10"><children><Label text="Secci&#243;n:" styleClass="detail-key" /><Label fx:id="detailNombreLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="Grado:" styleClass="detail-key" /><Label fx:id="detailGradoLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="Paralelo:" styleClass="detail-key" /><Label fx:id="detailParaleloLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="Cupo m&#225;ximo:" styleClass="detail-key" /><Label fx:id="detailCupoLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="A&#241;o lectivo:" styleClass="detail-key" /><Label fx:id="detailAnioLectivoLabel" text="-" /></children></HBox>
                        <HBox spacing="10"><children><Label text="Estado:" styleClass="detail-key" /><Label fx:id="detailEstadoLabel" text="-" styleClass="badge-like" /></children></HBox>
                      </children>
                    </VBox>
                    <VBox fx:id="formContent" spacing="12" visible="false" managed="false">
                      <children>
                        <Label text="Datos de la secci&#243;n" styleClass="section-heading" />
                        <VBox spacing="6"><children><Label text="Grado" styleClass="field-label" /><ComboBox fx:id="formGradoCombo" promptText="Selecciona un grado" /></children></VBox>
                        <VBox spacing="6"><children><Label text="Paralelo" styleClass="field-label" /><TextField fx:id="formParaleloField" promptText="Paralelo" /></children></VBox>
                        <VBox spacing="6"><children><Label text="Cupo m&#225;ximo" styleClass="field-label" /><Spinner fx:id="formCupoMaximoSpinner" editable="true" /></children></VBox>
                        <VBox spacing="6"><children><Label text="A&#241;o lectivo" styleClass="field-label" /><TextField fx:id="formAnioLectivoField" promptText="2026-2027" /></children></VBox>
                      </children>
                    </VBox>
                  </children>
                </VBox>
              </content>
            </ScrollPane>
            <ImageView fitWidth="236"
                       preserveRatio="true"
                       mouseTransparent="true"
                       styleClass="view-artwork-view drawer-watermark"
                       StackPane.alignment="BOTTOM_RIGHT" />
          </children>
        </StackPane>
        <HBox alignment="CENTER_RIGHT" spacing="10">
          <children>
            <Button fx:id="detailEditarButton" text="Editar" onAction="#onEditarDesdeDetalle" visible="false" managed="false" />
            <Button fx:id="detailEstadoButton" text="Inactivar" onAction="#onCambiarEstadoActual" visible="false" managed="false" />
            <Button fx:id="guardarButton" text="Guardar" onAction="#onGuardarFormulario" styleClass="primary-button" visible="false" managed="false" />
          </children>
        </HBox>
      </children>
    </VBox>
  </children>
</StackPane>
